		"@relicord/api": "workspace:*",
		"@relicord/auth": "workspace:*",
		"@relicord/db": "workspace:*",
		"@relicord/env": "workspace:*",
		"@trpc/server": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"fastify": "^5.8.4",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@relicord/config": "workspace:*",
		"@types/node": "catalog:",
		"tsdown": "^0.16.8",
		"tsx": "^4.21.0",
		"typescript": "catalog:"
	}
