{
	"name": "relicord",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @relicord/db db:push",
		"db:studio": "turbo -F @relicord/db db:studio",
		"db:generate": "turbo -F @relicord/db db:generate",
		"db:migrate": "turbo -F @relicord/db db:migrate",
		"deploy": "turbo -F @relicord/infra deploy",
		"destroy": "turbo -F @relicord/infra destroy",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@relicord/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@cloudflare/workers-types": "^4.20260317.1",
		"@relicord/config": "workspace:*",
		"@types/node": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"turbo": "^2.8.20",
		"typescript": "catalog:"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "pnpm@10.32.1"
}
